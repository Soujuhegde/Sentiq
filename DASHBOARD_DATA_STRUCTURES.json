    "fake_detection": {
      "description": "Fake review detection results",
      "endpoint": "GET /api/fake-detection",
      "example": {
        "summary": {
          "total_reviewed": 8492,
          "genuine": {
            "count": 7234,
            "percentage": 85.2,
            "avg_confidence": 0.94
          },
          "fake": {
            "count": 1258,
            "percentage": 14.8,
            "avg_confidence": 0.89
          }
        },
        "fake_categories": [
          {
            "type": "spam",
            "count": 450,
            "percentage": 5.3,
            "confidence": 0.96,
            "indicators": [
              "repetitive keywords",
              "excessive caps",
              "suspicious URLs"
            ],
            "examples": [
              "EARN MONEY FAST CLICK HERE NOW!!!!",
              "BEST DEAL EVER!!! VISIT US NOW!!!"
            ]
          },
          {
            "type": "bot_generated",
            "count": 320,
            "percentage": 3.8,
            "confidence": 0.92,
            "indicators": [
              "unnatural sentence structure",
              "repeated phrases",
              "template patterns"
            ],
            "examples": [
              "This product is good. I like it. You should buy it.",
              "The app works. The app is fast. The app is good."
            ]
          },
          {
            "type": "suspicious_user_behavior",
            "count": 488,
            "percentage": 5.7,
            "confidence": 0.81,
            "indicators": [
              "multiple reviews from same user",
              "rapid review posting",
              "unusual rating patterns"
            ],
            "examples": []
          }
        ],
        "trend": {
          "fake_percentage_7d": 14.8,
          "fake_percentage_30d": 16.2,
          "change": -1.4,
          "direction": "improving"
        }
      }
    },

