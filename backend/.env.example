# Sentiq Neural Environment Template
# Duplicate this file as '.env' and fill in your keys.

# Anthropic API Key for Sentiment Analysis and Chatbot
ANTHROPIC_API_KEY=your_sk_ant_key_here

# Database URL (Defaulting to Local SQLite)
DATABASE_URL=sqlite:///./sentiq.db

# Neural Node Config
LOG_LEVEL=INFO
DEBUG=True
